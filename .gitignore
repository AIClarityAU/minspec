node_modules/
out/
dist/
*.vsix
.vscode-test/
coverage/
*.log
.DS_Store

# Tool / cache directories
.wrangler/
# .claude/ is machine-local EXCEPT MinSpec's slash-command shims, which are part
# of the shared SDD harness (like AGENTS.md/.cursorrules) and must be tracked so
# the team/CI receive them (minspec#763). Carve those out of the ignore.
.claude/*
!.claude/commands/
.claude/commands/*
!.claude/commands/minspec-*.md
__pycache__/

# Agent-dispatch sidecars (DR-008 / scripts/dispatch-issue.sh) — worktree-local
# memos the parent reads and posts to the issue; must never leak into git history.
.agent-summary.md
.review-signals.json

# Secrets — never commit
.env
.env.*
!.env.example

# MinSpec ephemeral session data
.minspec/session.json
# SPEC-026 FR-1 session-presence heartbeat directory (one <uuid>.session.json per
# live activation, refreshed every 30s / pruned at 120s). Machine-local, ephemeral,
# never committed. Mirrors MINSPEC_GITIGNORE_ENTRIES in scaffold.ts (gitignore.test.ts
# ties the two together per the #794 root-mirror gate).
.minspec/sessions/
.minspec/calibration.json
# DR-057 §2 phase-advance request queue (#733) — path-keyed, machine-local
# request files the drain dequeues; must never leak into git history. Mirrors
# MINSPEC_GITIGNORE_ENTRIES in scaffold.ts (scaffolded projects already get it).
.minspec/queue/
# SPEC-024 auto-merge decision audit trail (FR-7). Machine-local, append-only,
# rebuilt/extended on every gate invocation — never committed.
.minspec/auto-merge-audit.log
# Machine-local merge-refresh drift-detection state, rebuilt on every
# generate/refresh — must be gitignored, never committed. Mirrors
# MINSPEC_GITIGNORE_ENTRIES in packages/minspec/src/lib/scaffold.ts (kept in
# sync by gitignore.test.ts). Backfilled here after a stale installed build
# wrote template-baseline.json without adding these entries (#380 follow-up).
.minspec/generated-hashes.json
.minspec/template-baseline.json

# Classifier validation: fetched SWE-bench data (DR-009 — patches not committed)
scripts/classifier-validation/.data/

# E2E test artifacts (regenerated by test runs)
packages/minspec/test-fixtures/workspace/.cursorrules
packages/minspec/test-fixtures/workspace/.vscode/
packages/minspec/test-fixtures/workspace/AGENTS.md
packages/minspec/test-fixtures/workspace/CLAUDE.md
packages/minspec/test-fixtures/workspace/DESIGN.md
packages/minspec/test-fixtures/workspace/specs/SPEC-EXAMPLE.md
packages/minspec/test-fixtures/workspace/.minspec/constitution.md
packages/minspec/test-fixtures/workspace/.minspec/generated-hashes.json

# Supply-chain scan output (bumblebee, DR-005)
.cache/supply-chain/

# SPEC-022 (DR-034): approval ground truth is now COMMITTED, path-keyed sidecars
# under .minspec/approvals/ (FR-1) — intentionally TRACKED so every clone/worktree/CI
# checkout has it. The legacy single-file .minspec/approvals.json stays ignored (it
# is migrated into the sidecar tree by scripts/migrate-approvals.ts and retired).
.minspec/approvals.json
.minspec/approvals.json.bak-*

# Auto-drain opt-in (#239) — personal/machine-local, never inherited by teammates
.minspec/auto-drain

# ScroogeLLM content lives in the private scroogellm repo, never in public MinSpec (DR-027).
# Gate: keep scrooge assets/site out of public history even if dropped into this tree.
sites/scroogellm.com/
