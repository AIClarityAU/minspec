{
  "name": "@aiclarity/scroogellm",
  "displayName": "ScroogeLLM",
  "description": "Every token counts.",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "publisher": "aiclarity",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "keywords": ["llm", "cost", "proxy", "tokens", "optimization"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scroogellm.start",
        "title": "ScroogeLLM: Start Proxy"
      },
      {
        "command": "scroogellm.stop",
        "title": "ScroogeLLM: Stop Proxy"
      },
      {
        "command": "scroogellm.dashboard",
        "title": "ScroogeLLM: Open Cost Dashboard"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run build -- --watch",
    "package": "node -e \"console.error('ScroogeLLM is in SDD Specify phase — not ready for marketplace. Blocked to prevent publishing an empty/incomplete extension (VSCode ToU §4.xiv, Open VSX §8b). Remove this guard once description, icon, README, LICENSE, and implementation are complete.'); process.exit(1)\"",
    "test": "vitest run"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  }
}
