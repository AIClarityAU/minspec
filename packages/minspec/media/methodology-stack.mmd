---
config:
  theme: dark
---
flowchart TB
 subgraph TOP[" "]
    direction LR
        TC["Tier Classifier<br>(MinSpec)"]
        CDD["CDD: Contract-Driven Development"]
        WSJF["WSJF Backlog<br>(SAFe)"]
  end
 subgraph SDD["SDD: Spec-Driven Development"]
    direction LR
        P1["Constitution"]
        P2["Specify"]
        P3["Clarify"]
        P4["Plan"]
        P5["Tasks"]
        P6["Analyze"]
        P7["Implement"]
  end
 subgraph BOTTOM[" "]
    direction LR
        ADR["Decision Register<br>(Nygard)"]
        BUG["RCDD: Root-Cause Driven Debugging (MinSpec)"]
        GTD["Session Scope + Parking Lot<br>(GTD)"]
  end
    TC --> SDD
    CDD --> SDD
    WSJF --> SDD
    P1 --> P2
    P2 --> P3
    P3 --> P4
    P4 --> P5
    P5 --> P6
    P6 --> P7
    ADR --> SDD
    BUG --> SDD
    GTD --> SDD
    %% Invisible anchors — force BOTTOM row to render below SDD without adding visible edges
    SDD ~~~ ADR
    SDD ~~~ BUG
    SDD ~~~ GTD

    TC@{ shape: rect}
    BUG@{ shape: rect}
    style P1 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style P2 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style P3 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style P4 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style P5 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style P6 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style P7 fill:#161922,stroke:#6c9cfc,stroke-width:1.5px,color:#e2e4eb
    style TC fill:#13291d,stroke:#5ec48a,stroke-width:2px,color:#9fe3bb
    style SDD fill:#141a2b,stroke:#6c9cfc,stroke-width:2px,color:#e2e4eb
    style CDD fill:#241a33,stroke:#a07bff,stroke-width:2px,color:#d9c9ff
    style BUG fill:#13291d,stroke:#5ec48a,stroke-width:2px,color:#9fe3bb
    style ADR fill:#20232e,stroke:#6b7280,stroke-width:2px,color:#c9ccd6
    style WSJF fill:#20232e,stroke:#6b7280,stroke-width:2px,color:#c9ccd6
