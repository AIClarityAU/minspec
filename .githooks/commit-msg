#!/usr/bin/env bash
# commit-msg — RCDD root-cause gate (DR-003).
#
# Bug-fix commits must document a root cause. If the subject is a Conventional
# Commit `fix` (fix:, fix(scope):, fix!:), the body MUST contain a line matching
# `Root cause:` (case-insensitive, space or hyphen). Otherwise the commit is
# rejected — enforcing RCDD Phase 2 (diagnose) before Phase 3 (fix lands).
#
# This is deterministic and actor-agnostic: it reads the *composed* message
# from $1, so it catches commits built via -m, heredoc, $(...) substitution, or
# the editor — by Claude or a human alike.
#
# Kill-switch: RCDD_GATE_OFF=1 git commit ...   (explicit, intentional bypass)
# Fail-open: any read error or missing message file -> allow (never block on a
# hook bug).

set -uo pipefail

# Explicit escape hatch.
if [ "${RCDD_GATE_OFF:-0}" = "1" ]; then
  exit 0
fi

MSG_FILE="${1:-}"
[ -n "$MSG_FILE" ] && [ -r "$MSG_FILE" ] || exit 0   # fail open

# Subject = first non-comment, non-empty line.
SUBJECT="$(grep -v '^#' "$MSG_FILE" | grep -m1 . || true)"

# Only gate Conventional-Commit fix subjects: fix:  fix(scope):  fix!:  fix(scope)!:
if ! printf '%s' "$SUBJECT" | grep -Eq '^fix(\([^)]*\))?!?:'; then
  # Not a fix commit -> the hard gate does not apply. But a bug fix mislabeled
  # as chore/refactor/style/perf dodges RCDD. Emit a NON-blocking advisory when
  # such a type carries bug-language and no documented root cause. Warning only
  # (exit 0) — refactors are legitimate; this nudges, never blocks.
  BODY="$(grep -v '^#' "$MSG_FILE" || true)"
  if printf '%s' "$SUBJECT" | grep -Eq '^(chore|refactor|style|perf)(\([^)]*\))?!?:' \
     && printf '%s' "$BODY" | grep -Eiq '\b(bug|bugfix|hotfix|regression|crash|segfault|broken|null deref|null pointer|off-by-one)\b' \
     && ! printf '%s' "$BODY" | grep -Eiq '\broot[ -]cause:'; then
    cat >&2 <<'EOF'
⚠ RCDD advisory (DR-003): this looks like a bug fix mislabeled as a non-fix type.

  Bug-language detected under a chore/refactor/style/perf subject with no
  `Root cause:` line. If it fixes a bug, prefer `fix:` and document the cause.
  Committing anyway (advisory only — not blocked).
EOF
  fi
  exit 0
fi

# Strip comment lines, then require a Root cause: marker anywhere in the body.
if grep -v '^#' "$MSG_FILE" | grep -Eiq '\broot[ -]cause:'; then
  exit 0
fi

cat >&2 <<'EOF'
✗ RCDD gate (DR-003): fix commit missing root cause.

  A `fix` commit must document the diagnosis. Add a body line:

      Root cause: <one sentence>

  RCDD Phase 2 (diagnose) precedes Phase 3 (fix). A fix without a stated
  root cause usually patches a symptom.

  Intentional bypass (rare):  RCDD_GATE_OFF=1 git commit ...
EOF
exit 1
